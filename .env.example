# API
APP_NAME=autopost-saas
DEBUG=false
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/autopost
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Telegram — my.telegram.org (userbot MTProto)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Aiogram Bot (faqat boshqaruv UI — xabarlar Telethon orqali)
BOT_TOKEN=

# Fernet key for session encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# Internal API for bot -> backend
INTERNAL_API_SECRET=change-me-long-random

# Sessions directory (mounted in Docker)
SESSIONS_DIR=/app/sessions

# DB pool (ixtiyoriy)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# Telethon ulanish
# TELETHON_TIMEOUT=60
# TELETHON_CONNECTION_RETRIES=3

# Yuborish / anti-ban
# SENDER_LOG_COMMIT_BATCH=12
# CAMPAIGN_LOCK_TTL_SECONDS=1800
# TYPING_SIMULATION_PROBABILITY=0.82
# POST_TYPING_PAUSE_FACTOR=0.55

# Celery process_campaign vaqt cheklovi (soniya)
# CAMPAIGN_SOFT_TIME_LIMIT_SECONDS=2400
# CAMPAIGN_TIME_LIMIT_SECONDS=3600
